# ── Edge TTS (Sonia Neural - British Female) ────────────────
import asyncio, io as _io

class EdgeTtsReq(BaseModel):
    text: str
    voice: str = "en-GB-SoniaNeural"

@app.post("/tts/edge")
async def tts_edge(req: EdgeTtsReq, _=Depends(require_auth)):
    import edge_tts
    text = _strip_for_tts(req.text or "")
    if not text:
        raise HTTPException(400, "empty text")
    communicate = edge_tts.Communicate(text, req.voice)
    buf = _io.BytesIO()
    async for chunk in communicate.stream():
        if chunk["type"] == "audio":
            buf.write(chunk["data"])
    audio = buf.getvalue()
    if not audio:
        raise HTTPException(500, "no audio returned")
    return Response(content=audio, media_type="audio/mpeg")
