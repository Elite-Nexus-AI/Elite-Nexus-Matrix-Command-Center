<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ELITE NEXUS // MATRIX HUD v2</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg:       oklch(0.12 0.02 260);
  --fg:       oklch(0.95 0.02 200);
  --card:     oklch(0.16 0.03 260 / 0.55);
  --muted:    oklch(0.18 0.03 260);
  --muted-fg: oklch(0.7 0.04 220);
  --border:   oklch(0.85 0.18 200 / 0.25);
  --cyan:     oklch(0.88 0.18 200);
  --mag:      oklch(0.7 0.28 330);
  --amber:    oklch(0.85 0.18 80);
  --lime:     oklch(0.88 0.22 140);
  --danger:   oklch(0.7 0.25 25);
  --ease-out: cubic-bezier(0.23, 1, 0.32, 1);
  --ease-io:  cubic-bezier(0.77, 0, 0.175, 1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{
  font-family:'Rajdhani','Inter',ui-sans-serif,sans-serif;
  background:var(--bg);color:var(--fg);
  background-image:
    radial-gradient(ellipse at 20% 10%,oklch(0.3 0.18 200/0.18),transparent 55%),
    radial-gradient(ellipse at 85% 90%,oklch(0.3 0.22 330/0.18),transparent 55%),
    linear-gradient(180deg,oklch(0.1 0.02 260),oklch(0.08 0.02 260));
}
.hud-grid{
  background-image:
    linear-gradient(oklch(0.85 0.18 200/0.06) 1px,transparent 1px),
    linear-gradient(90deg,oklch(0.85 0.18 200/0.06) 1px,transparent 1px);
  background-size:48px 48px;
}
.scanlines{
  position:absolute;inset:0;pointer-events:none;z-index:1;
  background-image:repeating-linear-gradient(0deg,oklch(0.85 0.18 200/0.04) 0px,oklch(0.85 0.18 200/0.04) 1px,transparent 1px,transparent 3px);
}
/* HUD TILE */
.tile{
  position:relative;display:flex;flex-direction:column;
  background:linear-gradient(135deg,rgba(0,0,0,0.88),rgba(3,6,18,0.94));
  border:1px solid oklch(0.85 0.18 200/0.35);
  box-shadow:inset 0 0 24px oklch(0.85 0.18 200/0.06),0 0 24px oklch(0.85 0.18 200/0.08),0 0 1px oklch(0.85 0.18 200/0.6);
  backdrop-filter:blur(6px);border-radius:2px;overflow:hidden;height:100%;
}
.tile::before,.tile::after{content:"";position:absolute;width:14px;height:14px;border-style:solid;border-color:var(--cyan);z-index:10;}
.tile::before{top:-1px;left:-1px;border-width:1px 0 0 1px;}
.tile::after{bottom:-1px;right:-1px;border-width:0 1px 1px 0;}
.tile-m{border-color:oklch(0.7 0.28 330/0.45);box-shadow:inset 0 0 24px oklch(0.7 0.28 330/0.08),0 0 24px oklch(0.7 0.28 330/0.1);}
.tile-m::before,.tile-m::after{border-color:var(--mag);}
.th{display:flex;align-items:center;justify-content:space-between;padding:6px 10px 5px;border-bottom:1px solid oklch(0.85 0.18 200/0.18);font-family:'JetBrains Mono',monospace;font-size:9px;text-transform:uppercase;letter-spacing:.3em;flex-shrink:0;}
.th-c{color:var(--cyan)}.th-m{color:var(--mag)}.th-s{color:var(--muted-fg)}
.tb{padding:10px;flex:1;min-height:0;display:flex;flex-direction:column;}
/* Sweep animation */
.sweep{overflow:hidden;}
.sweep::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent,oklch(0.85 0.18 200/0.12) 50%,transparent);animation:scanSweep 3.5s linear infinite;pointer-events:none;z-index:5;}
/* Text glow */
.gc{color:var(--cyan);text-shadow:0 0 8px oklch(0.85 0.18 200/0.7),0 0 18px oklch(0.85 0.18 200/0.35);}
.gm{color:var(--mag);text-shadow:0 0 8px oklch(0.7 0.28 330/0.75),0 0 18px oklch(0.7 0.28 330/0.35);}
.ga{color:var(--amber);text-shadow:0 0 8px oklch(0.85 0.18 80/0.7);}
.gl{color:var(--lime);text-shadow:0 0 8px oklch(0.88 0.22 140/0.7);}
.mono{font-family:'JetBrains Mono',monospace;}
.ticking{animation:ticking 1.2s steps(2,end) infinite;}
.glitch{animation:glitch 4.5s steps(1) infinite;}
/* Keyframes */
@keyframes heartbeat{0%{transform:scale(1)}14%{transform:scale(1.07)}28%{transform:scale(1)}42%{transform:scale(1.05)}70%{transform:scale(1)}100%{transform:scale(1)}}
@keyframes scanSweep{0%{transform:translateY(-100%)}100%{transform:translateY(100%)}}
@keyframes ticking{0%,100%{opacity:1}50%{opacity:.55}}
@keyframes glitch{0%,92%,100%{transform:translate(0,0);text-shadow:0 0 8px var(--cyan)}93%{transform:translate(-1px,0);text-shadow:1px 0 var(--mag),-1px 0 var(--cyan)}95%{transform:translate(1px,-1px);text-shadow:-1px 0 var(--mag),1px 0 var(--cyan)}97%{transform:translate(0,1px);text-shadow:0 0 8px var(--cyan)}}
@keyframes rotateSlow{to{transform:rotate(360deg)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:.6}50%{opacity:1}}
/* Layout */
#app{position:fixed;inset:0;display:flex;flex-direction:column;}
#topbar{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:8px 16px;border-bottom:1px solid oklch(0.85 0.18 200/0.25);background:oklch(0.12 0.03 260/0.6);backdrop-filter:blur(6px);z-index:50;flex-shrink:0;}
.tb-left{display:flex;align-items:center;gap:12px;font-family:'JetBrains Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.3em;}
.tb-right{display:flex;align-items:center;gap:12px;font-family:'JetBrains Mono',monospace;font-size:11px;}
.bridge-dot{width:8px;height:8px;border-radius:50%;}
.icon-btn{padding:3px 8px;border:1px solid oklch(0.85 0.18 200/0.35);border-radius:2px;background:none;cursor:pointer;color:var(--muted-fg);font-family:'JetBrains Mono',monospace;font-size:10px;display:flex;align-items:center;gap:5px;transition:color .2s,border-color .2s;}
.icon-btn:hover{color:var(--cyan);border-color:var(--cyan);}
#hud{flex:1;display:grid;gap:14px;padding:14px;min-height:0;overflow:auto;grid-template-columns:minmax(280px,1.05fr) minmax(0,1.35fr) minmax(280px,1.05fr);grid-template-rows:auto auto 1fr;}
/* GPU */
.gpu-body{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:10px;flex:1;}
.gpu-bars{grid-column:1/-1;display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:4px;}
.gauge-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;}
.gauge-svg{transform:rotate(-90deg);}
.gauge-lbl-wrap{position:absolute;display:flex;flex-direction:column;align-items:center;pointer-events:none;}
.gauge-val{font-family:'JetBrains Mono',monospace;font-size:22px;font-weight:600;}
.gauge-unit{font-size:11px;opacity:.8;}
.gauge-lbl-txt{font-family:'JetBrains Mono',monospace;font-size:9px;text-transform:uppercase;letter-spacing:.25em;color:var(--muted-fg);margin-top:2px;}
.bar-wrap{}
.bar-hdr{display:flex;justify-content:space-between;font-family:'JetBrains Mono',monospace;font-size:9px;text-transform:uppercase;letter-spacing:.2em;color:var(--muted-fg);margin-bottom:4px;}
.bar-track{height:6px;background:oklch(0.2 0.02 260);overflow:hidden;border-radius:1px;}
.bar-fill{height:100%;border-radius:1px;transition:width .5s var(--ease-out);}
/* CPU */
.cpu-body{display:grid;grid-template-columns:auto 1fr;gap:12px;padding:10px;flex:1;min-height:0;}
.cpu-big{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;padding-right:12px;border-right:1px solid oklch(0.85 0.18 200/0.2);}
.cpu-pct{font-family:'JetBrains Mono',monospace;font-size:36px;font-weight:600;line-height:1;}
.cpu-right{display:flex;flex-direction:column;gap:8px;min-height:0;}
.core-bars{display:grid;grid-template-columns:repeat(12,1fr);gap:3px;height:48px;align-items:end;}
.core-col{position:relative;height:100%;background:oklch(0.18 0.02 260);overflow:hidden;}
.core-fill{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(180deg,oklch(0.7 0.28 330),oklch(0.85 0.18 200));box-shadow:0 0 6px var(--cyan);transition:height .5s var(--ease-out);}
/* LLM */
.llm-body{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:10px;flex:1;min-height:0;}
.llm-stat{display:flex;flex-direction:column;justify-content:center;align-items:center;}
.llm-stat.br{border-right:1px solid oklch(0.7 0.28 330/0.25);padding-right:12px;}
.llm-val{font-family:'JetBrains Mono',monospace;font-size:28px;font-weight:600;}
.llm-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;text-transform:uppercase;letter-spacing:.25em;color:var(--muted-fg);}
.llm-sub{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted-fg);margin-top:2px;}
.llm-models{grid-column:1/-1;display:flex;flex-direction:column;gap:3px;overflow-y:auto;max-height:100px;}
.llm-row{display:flex;align-items:center;justify-content:space-between;font-family:'JetBrains Mono',monospace;font-size:10px;padding:3px 0;border-bottom:1px solid oklch(0.85 0.18 200/0.08);}
.mdot{display:inline-block;width:6px;height:6px;margin-right:8px;}
/* Agents */
.agents-body{flex:1;display:flex;flex-direction:column;gap:4px;padding:8px 10px;overflow-y:auto;min-height:0;}
.agent-row{display:flex;align-items:center;gap:10px;padding:5px 8px;border-left:2px solid;cursor:pointer;transition:background .2s;border-radius:0 2px 2px 0;}
.agent-row:hover{background:oklch(0.85 0.18 200/0.05);}
.agent-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.agent-info{flex:1;min-width:0;}
.agent-name{font-family:'JetBrains Mono',monospace;font-size:13px;}
.agent-task{font-family:'JetBrains Mono',monospace;font-size:10px;color:oklch(0.9 0.02 200/0.7);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.agent-el{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted-fg);width:36px;text-align:right;}
/* Vault */
.vault-body{flex:1;position:relative;min-height:200px;}
.vault-canvas{position:absolute;inset:0;width:100%;height:100%;display:block;touch-action:none;}
/* CHAT */
.chat-tile{display:flex;flex-direction:column;height:100%;overflow:hidden;}
.chat-inner{display:flex;flex-direction:column;flex:1;min-height:0;padding:8px 10px 10px;}
.chat-pills{display:flex;align-items:center;gap:6px;flex-wrap:wrap;font-size:9px;text-transform:uppercase;letter-spacing:.25em;margin-bottom:8px;flex-shrink:0;}
.pill{display:inline-flex;align-items:center;gap:4px;padding:2px 6px;border:1px solid;border-radius:2px;font-family:'JetBrains Mono',monospace;font-size:9px;text-transform:uppercase;letter-spacing:.25em;}
.pill-on{border-color:var(--lime);color:var(--lime);box-shadow:0 0 8px oklch(0.88 0.22 140/0.5);}
.pill-off{border-color:oklch(0.5 0.04 220);color:oklch(0.6 0.04 220);}
.sel-wrap{position:relative;}
.hud-sel{background:oklch(0.12 0.03 260);border:1px solid oklch(0.85 0.18 200/0.4);border-radius:2px;color:var(--cyan);font-family:'JetBrains Mono',monospace;font-size:9px;padding:2px 6px;cursor:pointer;text-transform:uppercase;}
.hud-sel:focus{outline:none;border-color:var(--cyan);}
.persona-btn{display:inline-flex;align-items:center;gap:4px;padding:2px 6px;border:1px solid var(--mag);border-radius:2px;color:var(--mag);box-shadow:0 0 8px oklch(0.7 0.28 330/0.4);background:none;cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:9px;text-transform:uppercase;letter-spacing:.25em;}
.persona-dd{position:absolute;top:100%;left:0;margin-top:4px;min-width:160px;border:1px solid var(--mag);background:oklch(0.1 0.03 260/0.96);backdrop-filter:blur(8px);border-radius:2px;box-shadow:0 0 12px oklch(0.7 0.28 330/0.4);z-index:100;display:none;}
.persona-dd.open{display:block;}
.persona-opt{display:block;width:100%;text-align:left;padding:6px 8px;background:none;border:none;cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:10px;}
.persona-opt:hover{background:oklch(0.7 0.28 330/0.12);}
.clear-btn{display:inline-flex;align-items:center;gap:4px;padding:2px 6px;border:1px solid oklch(0.7 0.25 25/0.6);border-radius:2px;color:oklch(0.85 0.18 25);background:none;cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:9px;text-transform:uppercase;letter-spacing:.25em;}
.mdl-badge{margin-left:auto;color:var(--muted-fg);font-size:9px;font-family:'JetBrains Mono',monospace;}
/* Drop zone */
#msgs{flex:1;overflow-y:auto;padding:8px 12px;background:oklch(0.07 0.02 260/0.7);border:1px solid oklch(0.85 0.18 200/0.18);border-radius:2px;min-height:0;position:relative;}
#msgs.drag-over{border-color:var(--mag);box-shadow:0 0 20px oklch(0.7 0.28 330/0.4);}
.drop-hint{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:oklch(0.1 0.03 260/0.85);font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--mag);text-transform:uppercase;letter-spacing:.3em;pointer-events:none;opacity:0;transition:opacity .2s;}
#msgs.drag-over .drop-hint{opacity:1;}
.msg{margin-bottom:8px;animation:fadeUp .15s ease;}
.msg-user .pu{color:var(--lime)}.msg-user .pp{color:var(--muted-fg)}.msg-user .ph{color:var(--cyan)}.msg-user .pd{color:var(--muted-fg)}
.msg-ai .ai-m{color:var(--mag);text-shadow:0 0 8px oklch(0.7 0.28 330/0.75);}
.msg-ai .ai-at{color:var(--muted-fg)}.msg-ai .ai-h{color:var(--cyan)}
.ai-body{padding-left:12px;border-left:1px solid oklch(0.7 0.28 330/0.4);margin-top:2px;color:oklch(0.95 0.02 200/0.95);white-space:pre-wrap;word-break:break-word;}
.msg-sys{color:var(--muted-fg);font-style:italic;}
.sys-tag{color:var(--cyan);text-shadow:0 0 8px oklch(0.85 0.18 200/0.7);font-style:normal;}
.img-preview{max-width:200px;max-height:150px;border:1px solid oklch(0.85 0.18 200/0.3);border-radius:2px;margin-top:4px;}
/* Command bar */
.cmd-bar{display:flex;align-items:stretch;gap:8px;margin-top:8px;flex-shrink:0;}
.cmd-btn{display:flex;align-items:center;justify-content:center;width:40px;border:1px solid;border-radius:2px;background:none;cursor:pointer;transition:transform .1s;flex-shrink:0;position:relative;}
.cmd-btn:active{transform:scale(.97)}
.cmd-btn:disabled{opacity:.4}
.cmd-input-wrap{flex:1;min-width:0;display:flex;align-items:flex-start;gap:4px;padding:6px 8px;border:1px solid oklch(0.85 0.18 200/0.4);border-radius:2px;background:oklch(0.07 0.02 260/0.8);transition:box-shadow .2s;}
.cmd-input-wrap:focus-within{box-shadow:0 0 12px var(--cyan);}
.cmd-dollar{color:var(--mag);font-size:12px;flex-shrink:0;padding-top:1px;font-family:'JetBrains Mono',monospace;}
.cmd-ta{flex:1;min-width:0;background:transparent;border:none;outline:none;resize:none;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--fg);caret-color:var(--cyan);line-height:1.5;overflow:hidden;}
.cmd-ta::placeholder{color:oklch(0.7 0.04 220/0.7);}
.send-btn{display:flex;align-items:center;gap:6px;padding:0 12px;border:1px solid;border-radius:2px;background:none;cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.2em;transition:transform .1s;flex-shrink:0;}
.send-btn:active{transform:scale(.97)}.send-btn:disabled{opacity:.4}
.rec-dot{position:absolute;top:-4px;right:-4px;width:8px;height:8px;border-radius:50%;background:var(--danger);box-shadow:0 0 8px var(--danger);}
/* CENTER LOGO */
#logo-wrap{position:relative;display:flex;flex-direction:column;align-items:center;justify-content:center;user-select:none;pointer-events:none;width:320px;height:380px;}
#logo-bg{position:absolute;animation:rotateSlow 22s linear infinite;filter:drop-shadow(0 0 12px var(--cyan));}
#logo-eq{position:absolute;}
#logo-img-w{position:relative;z-index:10;width:240px;height:240px;animation:heartbeat 1.6s var(--ease-io) infinite;transition:filter .4s var(--ease-out);filter:drop-shadow(0 0 18px var(--cyan)) drop-shadow(0 0 44px oklch(0.85 0.18 200/0.45));}
#logo-img-w.active{filter:drop-shadow(0 0 24px var(--mag)) drop-shadow(0 0 60px oklch(0.7 0.28 330/0.55));}
#logo-img{width:100%;height:100%;object-fit:contain;}
#logo-status{position:absolute;bottom:6px;left:0;right:0;text-align:center;font-family:'JetBrains Mono',monospace;}
#logo-sub{font-size:10px;text-transform:uppercase;letter-spacing:.5em;color:var(--muted-fg);}
#logo-main{font-size:14px;text-transform:uppercase;letter-spacing:.4em;}
/* AGENT COMMANDER MODAL */
.modal-ov{display:none;position:fixed;inset:0;background:oklch(0 0 0/0.75);backdrop-filter:blur(4px);z-index:200;align-items:center;justify-content:center;}
.modal-ov.open{display:flex;}
.modal-box{background:oklch(0.14 0.03 260);border:1px solid oklch(0.85 0.18 200/0.5);border-radius:2px;padding:24px;width:520px;max-width:95vw;box-shadow:0 0 40px oklch(0.85 0.18 200/0.15);max-height:90vh;overflow-y:auto;}
.modal-title{font-family:'JetBrains Mono',monospace;font-size:12px;text-transform:uppercase;letter-spacing:.3em;color:var(--cyan);text-shadow:0 0 8px oklch(0.85 0.18 200/0.7);margin-bottom:20px;}
.modal-field{margin-bottom:12px;}
.modal-label{display:block;font-family:'JetBrains Mono',monospace;font-size:9px;text-transform:uppercase;letter-spacing:.25em;color:var(--muted-fg);margin-bottom:5px;}
.modal-input,.modal-textarea,.modal-select{width:100%;background:oklch(0.18 0.03 260);border:1px solid oklch(0.85 0.18 200/0.3);border-radius:2px;padding:6px 8px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--fg);outline:none;transition:border-color .2s,box-shadow .2s;}
.modal-input:focus,.modal-textarea:focus,.modal-select:focus{border-color:var(--cyan);box-shadow:0 0 8px oklch(0.85 0.18 200/0.3);}
.modal-textarea{resize:vertical;min-height:80px;}
.modal-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:20px;}
.modal-btn{padding:6px 16px;border:1px solid;border-radius:2px;background:none;cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:.2em;}
.btn-c{border-color:var(--cyan);color:var(--cyan);box-shadow:0 0 8px oklch(0.85 0.18 200/0.3);}
.btn-m{border-color:var(--mag);color:var(--mag);box-shadow:0 0 8px oklch(0.7 0.28 330/0.3);}
.btn-dim{border-color:oklch(0.5 0.04 220);color:oklch(0.7 0.04 220);}
/* Row 2/3 spans */
.r2{grid-column:1/-1;display:grid;gap:14px;grid-template-columns:1.2fr 1fr 1fr;}
.r3{grid-column:1/-1;display:grid;gap:14px;grid-template-columns:1fr 1.8fr 1fr 1fr;min-height:340px;}
/* Scrollbar */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:oklch(0.85 0.18 200/0.25);border-radius:2px}
::-webkit-scrollbar-thumb:hover{background:oklch(0.85 0.18 200/0.45)}
/* Init */
#init{display:flex;flex:1;align-items:center;justify-content:center;}
.init-txt{font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--cyan);text-shadow:0 0 8px oklch(0.85 0.18 200/0.7);animation:ticking 1.2s steps(2,end) infinite;letter-spacing:.1em;}
.svg-icon{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.svg-sm{width:12px;height:12px;}

/* Income Factory Dashboard */
.factory-panel{background:oklch(0.08 0.02 220/0.95);border:1px solid var(--cyan);border-radius:8px;padding:16px;margin:8px 0;}
.factory-title{color:var(--cyan);font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;}
.factory-metric{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid oklch(0.3 0.05 220/0.3);}
.factory-metric:last-child{border-bottom:none;}
.factory-label{color:oklch(0.7 0.05 220);font-size:11px;}
.factory-value{color:var(--cyan);font-family:'Share Tech Mono',monospace;font-size:13px;font-weight:700;}
.factory-value.green{color:oklch(0.8 0.2 142);}
.factory-value.mag{color:var(--mag);}
.factory-alpha{border-color:var(--cyan);}
.factory-beta{border-color:var(--mag);}
.factory-vs{text-align:center;color:oklch(0.5 0.05 220);font-size:10px;padding:4px;}
.llm-route-badge{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:12px;font-size:10px;font-family:'Share Tech Mono',monospace;}
.llm-route-badge.local{background:oklch(0.2 0.15 142/0.3);border:1px solid oklch(0.6 0.2 142);color:oklch(0.8 0.2 142);}
.llm-route-badge.cloud{background:oklch(0.2 0.15 260/0.3);border:1px solid var(--cyan);color:var(--cyan);}
.briefing-btn{background:oklch(0.15 0.1 220/0.5);border:1px solid var(--cyan);color:var(--cyan);padding:6px 14px;border-radius:4px;font-family:'Share Tech Mono',monospace;font-size:10px;cursor:pointer;letter-spacing:1px;transition:all 0.2s;}
.briefing-btn:hover{background:oklch(0.25 0.15 220/0.5);box-shadow:0 0 8px var(--cyan);}


/* ── TELEMETRY FOOTER ─────────────────────────────────────────────── */
#tel-bar{
  position:fixed;bottom:0;left:0;right:0;height:22px;
  background:oklch(0.08 0.03 260/0.95);border-top:1px solid oklch(0.85 0.18 200/0.15);
  display:flex;align-items:center;gap:0;z-index:9999;
  font-family:'JetBrains Mono',monospace;font-size:8px;
  user-select:none;backdrop-filter:blur(8px);
}
.tel-seg{
  display:flex;align-items:center;gap:4px;padding:0 10px;
  border-right:1px solid oklch(0.85 0.18 200/0.1);height:100%;
}
.tel-label{color:oklch(0.5 0.05 200);font-size:7px;letter-spacing:.5px;text-transform:uppercase}
.tel-val{font-weight:bold}
.tel-val.free{color:#00ff88}
.tel-val.paid{color:#ffd700}
.tel-val.warn{color:#ff3333;animation:telwarn 1s ease-in-out infinite}
@keyframes telwarn{0%,100%{opacity:1}50%{opacity:.4}}
.tel-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.tel-dot.free{background:#00ff88;box-shadow:0 0 4px #00ff88}
.tel-dot.paid{background:#ffd700;box-shadow:0 0 4px #ffd700}
.tel-spacer{flex:1}
#tel-model-badge{
  font-size:7px;padding:1px 6px;border-radius:2px;border:1px solid;
  letter-spacing:.5px;margin-right:4px;
}
body{padding-bottom:22px}

/* ── PROJECT MODAL & COUNCIL BOX ─────────────────────────── */
.modal-overlay{
  display:none;position:fixed;inset:0;background:#000000cc;
  z-index:10000;align-items:center;justify-content:center;
}
.modal-overlay.open{display:flex}
.modal-box{
  background:#09101d;border:1px solid #00e5ff30;border-radius:6px;
  width:580px;max-width:95vw;max-height:85vh;overflow-y:auto;
  box-shadow:0 0 40px #00e5ff15;
}
.modal-hdr{
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 16px;border-bottom:1px solid #00e5ff15;
  background:#060d18;border-radius:6px 6px 0 0;
}
.modal-title{font-size:10px;letter-spacing:2px;color:#00e5ff;font-weight:bold}
.modal-close{background:transparent;border:1px solid #ff333530;color:#ff3333;
  width:22px;height:22px;border-radius:2px;cursor:pointer;font-size:12px;
  display:flex;align-items:center;justify-content:center}
.modal-body{padding:14px 16px}
.form-group{margin-bottom:12px}
.form-label{font-size:7px;letter-spacing:1.5px;color:#00e5ff66;
  display:block;margin-bottom:4px}
.form-input,.form-select,.form-textarea{
  width:100%;background:#060d18;border:1px solid #00e5ff18;
  color:#00e5ff;padding:6px 8px;font-size:9px;font-family:'Courier New',monospace;
  border-radius:3px;outline:none;transition:border-color .2s;
}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:#00e5ff40}
.form-input::placeholder,.form-textarea::placeholder{color:#00e5ff22}
.form-select option{background:#09101d}
.form-textarea{resize:vertical;min-height:60px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.tool-chips{display:flex;gap:4px;flex-wrap:wrap;margin-top:4px}
.tool-chip{padding:2px 8px;border:1px solid #00e5ff18;border-radius:2px;
  font-size:7px;color:#00e5ff44;cursor:pointer;transition:all .15s;
  font-family:'Courier New',monospace}
.tool-chip.selected{border-color:#00e5ff;color:#00e5ff;background:#00e5ff12}
.modal-footer{padding:10px 16px;border-top:1px solid #00e5ff12;
  display:flex;gap:8px;justify-content:flex-end;background:#060d18;
  border-radius:0 0 6px 6px}
.btn-primary{padding:6px 16px;background:linear-gradient(135deg,#00e5ff18,#ff00ff18);
  border:1px solid #00e5ff40;color:#00e5ff;font-family:inherit;font-size:8px;
  letter-spacing:1px;cursor:pointer;border-radius:3px;transition:all .2s}
.btn-primary:hover{background:linear-gradient(135deg,#00e5ff25,#ff00ff25)}
.btn-secondary{padding:6px 16px;background:transparent;border:1px solid #ffffff15;
  color:#ffffff44;font-family:inherit;font-size:8px;cursor:pointer;border-radius:3px}
/* COUNCIL */
.council-dropzone{
  background:#08101e;border:2px dashed #aa44ff28;border-radius:4px;
  padding:16px;text-align:center;cursor:pointer;transition:all .2s;
  margin-bottom:10px;
}
.council-dropzone:hover,.council-dropzone.drag-over{
  border-color:#aa44ff55;background:#0e0818}
.council-dropzone-title{font-size:9px;color:#aa44ff77;
  letter-spacing:1px;font-weight:bold;margin-bottom:4px}
.council-dropzone-sub{font-size:7px;color:#ffffff20;line-height:1.5}
.council-result{
  background:#060d18;border:1px solid #aa44ff20;border-radius:3px;
  padding:10px;font-size:8px;line-height:1.6;color:#ffffff66;
  white-space:pre-wrap;max-height:300px;overflow-y:auto;
  display:none;margin-top:10px;
}
.council-result.visible{display:block}
.council-thinking{color:#aa44ff88;font-size:8px;padding:8px;text-align:center;display:none}
.council-thinking.visible{display:block}
/* PROJECT LIST */
.proj-item{display:flex;align-items:center;gap:8px;padding:4px 6px;
  border-bottom:1px solid #00e5ff08;font-size:8px}
.proj-svc{font-size:6px;padding:1px 4px;border:1px solid #00e5ff18;
  color:#00e5ff55;border-radius:2px;flex-shrink:0}
.proj-name{flex:1;color:#00e5ffaa;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
</style>
</head>
<body>
<div id="app" class="hud-grid">
  <div class="scanlines"></div>

  <!-- TOP BAR -->
  <div id="topbar" style="display:flex;align-items:center;justify-content:space-between;gap:0;padding:0 16px;border-bottom:1px solid oklch(0.85 0.18 200/0.25);background:oklch(0.08 0.03 260/0.95);backdrop-filter:blur(12px);z-index:50;flex-shrink:0;height:44px;">

    <!-- LEFT: BRAND -->
    <div style="display:flex;align-items:center;gap:12px;flex-shrink:0">
      <span class="gc glitch" style="font-size:11px;letter-spacing:3px;white-space:nowrap">ELITE NEXUS // MATRIX</span>
      <div style="display:flex;align-items:center;gap:6px">
        <span class="bridge-dot ticking" id="bridge-dot" style="background:var(--danger);box-shadow:0 0 8px var(--danger);width:7px;height:7px;border-radius:50%;flex-shrink:0"></span>
        <span id="bridge-status" style="color:var(--danger);font-size:9px;letter-spacing:1px">OFFLINE</span>
      </div>
    </div>

    <!-- CENTER: NAV MENU -->
    <nav style="display:flex;align-items:center;gap:2px;flex:1;justify-content:center">
      <div class="nav-group">
        <button class="nav-btn" onclick="openProjectModal()">📋 PROJECTS</button>
      </div>
      <div class="nav-group">
        <button class="nav-btn" onclick="openCouncilModal()">🏛 COUNCIL</button>
      </div>
      <div class="nav-group">
        <button class="nav-btn" onclick="navToggleIngestor()" title="Knowledge Ingestor - drag &amp; drop files/URLs">📥 INGEST</button>
      </div>
      <div class="nav-group">
        <button class="nav-btn" onclick="document.getElementById('agent-roster-panel').classList.toggle('open')" title="Department Head Agents">⬡ AGENTS</button>
      </div>
      <div class="nav-group">
        <button class="nav-btn" onclick="document.getElementById('vault-assign-panel').classList.toggle('open')" title="Vault Assignment per Agent">🗄 VAULTS</button>
      </div>
      <div class="nav-group">
        <button class="nav-btn nav-btn-ceo" id="ceo-route-toggle" onclick="toggleAutoRoute()" title="CEO Auto-routes messages to correct dept head">⬡ CEO AUTO</button>
      </div>
      <div class="nav-group">
        <button class="nav-btn" onclick="navCfoBrief()" title="CFO Agent generates factory performance brief">₿ CFO</button>
      </div>
      <div class="nav-group">
        <button class="nav-btn" onclick="navMorningBrief()" title="Morning briefing - Gmail + Calendar">🌅 BRIEF</button>
      </div>
      <div class="nav-group">
        <button class="nav-btn" onclick="navFactoryStatus()" title="View all 5 factory revenues">⚡ FACTORY</button>
      </div>
      <div class="nav-group">
        <button class="nav-btn" onclick="navVaultSync()" title="Sync and refresh Obsidian vaults">🔄 SYNC</button>
      </div>
    </nav>

    <!-- RIGHT: STATUS -->
    <div style="display:flex;align-items:center;gap:10px;flex-shrink:0">
      <span id="tb-date" style="color:oklch(0.6 0.02 200);font-size:9px;letter-spacing:1px"></span>
      <span id="tb-time" class="gc" style="font-size:11px;letter-spacing:1px"></span>
      <button class="nav-btn" onclick="openModal('settings-modal')" style="border-color:oklch(0.85 0.18 200/0.3)">⚙</button>
      <span style="color:var(--muted-fg);font-size:9px;display:none" id="spec-label">I9 · 2×3090 · 128GB</span>
    </div>
  </div>

  <style>
  .nav-btn{
    padding:4px 10px;border:1px solid oklch(0.85 0.18 200/0.2);
    border-radius:3px;background:transparent;cursor:pointer;
    color:oklch(0.7 0.1 200);font-family:'JetBrains Mono',monospace;
    font-size:8.5px;letter-spacing:1px;text-transform:uppercase;
    transition:all .15s;white-space:nowrap;
  }
  .nav-btn:hover{
    color:var(--cyan);border-color:oklch(0.85 0.18 200/0.6);
    background:oklch(0.85 0.18 200/0.06);
    box-shadow:0 0 8px oklch(0.85 0.18 200/0.2);
  }
  .nav-btn-ceo{border-color:oklch(0.85 0.18 200/0.35);color:var(--cyan);}
  .nav-btn-ceo:hover{box-shadow:0 0 12px oklch(0.85 0.18 200/0.35);}
  .nav-group{position:relative;}
  </style>

  <!-- INIT -->
  <div id="init"><span class="init-txt">▌INITIALIZING MATRIX HUD v2…</span></div>

  <!-- HUD GRID -->
  <div id="hud" style="display:none">
    <!-- Row 1 -->
    <div style="min-height:260px;display:flex;flex-direction:column">
      <div class="tile sweep" style="flex:1" id="gpu0-tile">
        <div class="th"><span class="th-c" id="gpu0-title">GPU 0 • RTX 3090</span><span class="th-s" id="gpu0-fan">0% FAN</span></div>
        <div class="gpu-body">
          <div class="gauge-wrap" id="gpu0-temp"></div>
          <div class="gauge-wrap" id="gpu0-util"></div>
          <div class="gpu-bars">
            <div class="bar-wrap" id="gpu0-vram"></div>
            <div class="bar-wrap" id="gpu0-pwr"></div>
          </div>
        </div>
      </div>
    </div>

    <div style="display:flex;align-items:center;justify-content:center;position:relative;min-height:300px">
      <div id="logo-wrap">
        <svg id="logo-bg" width="320" height="320" viewBox="0 0 320 320">
          <circle cx="160" cy="160" r="150" fill="none" stroke="oklch(0.85 0.18 200/0.25)" stroke-width=".6" stroke-dasharray="2 6"/>
          <circle cx="160" cy="160" r="138" fill="none" stroke="oklch(0.7 0.28 330/0.35)" stroke-width=".6" stroke-dasharray="1 8"/>
        </svg>
        <svg id="logo-eq" width="320" height="320" viewBox="0 0 320 320" aria-hidden="true"></svg>
        <div id="logo-img-w">
          <svg id="cyber-heart" viewBox="0 0 240 240" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%">
            <defs>
              <radialGradient id="reactorGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#00e5ff" stop-opacity="0.6"/>
                <stop offset="40%" stop-color="#00e5ff" stop-opacity="0.15"/>
                <stop offset="100%" stop-color="#00e5ff" stop-opacity="0"/>
              </radialGradient>
              <radialGradient id="coreGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#ffffff" stop-opacity="1"/>
                <stop offset="30%" stop-color="#00e5ff" stop-opacity="0.9"/>
                <stop offset="100%" stop-color="#00e5ff" stop-opacity="0"/>
              </radialGradient>
              <radialGradient id="heartGrad" cx="50%" cy="40%" r="60%">
                <stop offset="0%" stop-color="#ff00ff" stop-opacity="0.25"/>
                <stop offset="60%" stop-color="#00e5ff" stop-opacity="0.12"/>
                <stop offset="100%" stop-color="#000010" stop-opacity="0"/>
              </radialGradient>
              <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="4" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
              <filter id="strongglow" x="-100%" y="-100%" width="300%" height="300%">
                <feGaussianBlur stdDeviation="8" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
              <clipPath id="heartClip">
                <path d="M120,175 C120,175 52,135 52,90 C52,65 70,48 92,48 C106,48 118,57 120,64 C122,57 134,48 148,48 C170,48 188,65 188,90 C188,135 120,175 120,175 Z"/>
              </clipPath>
            </defs>

            <!-- Outer rotating ring -->
            <g style="transform-origin:120px 120px;animation:rotateSlow 12s linear infinite">
              <circle cx="120" cy="120" r="108" fill="none" stroke="#00e5ff" stroke-width="0.5" stroke-opacity="0.3" stroke-dasharray="3 9"/>
              <circle cx="120" cy="12" r="3" fill="#00e5ff" opacity="0.7"/>
              <circle cx="120" cy="228" r="2" fill="#ff00ff" opacity="0.5"/>
              <circle cx="12" cy="120" r="2" fill="#00e5ff" opacity="0.5"/>
              <circle cx="228" cy="120" r="2" fill="#00e5ff" opacity="0.5"/>
            </g>

            <!-- Second counter-rotating ring -->
            <g style="transform-origin:120px 120px;animation:rotateSlow 20s linear infinite reverse">
              <circle cx="120" cy="120" r="92" fill="none" stroke="#ff00ff" stroke-width="0.4" stroke-opacity="0.2" stroke-dasharray="1 12"/>
            </g>

            <!-- Heart shape fill -->
            <path d="M120,175 C120,175 52,135 52,90 C52,65 70,48 92,48 C106,48 118,57 120,64 C122,57 134,48 148,48 C170,48 188,65 188,90 C188,135 120,175 120,175 Z"
              fill="url(#heartGrad)" filter="url(#glow)"/>

            <!-- Heart outline with glow -->
            <path d="M120,175 C120,175 52,135 52,90 C52,65 70,48 92,48 C106,48 118,57 120,64 C122,57 134,48 148,48 C170,48 188,65 188,90 C188,135 120,175 120,175 Z"
              fill="none" stroke="#00e5ff" stroke-width="1.2" stroke-opacity="0.7" filter="url(#glow)"/>

            <!-- Circuit lines inside heart -->
            <g clip-path="url(#heartClip)" opacity="0.4">
              <line x1="80" y1="70" x2="160" y2="70" stroke="#00e5ff" stroke-width="0.5" stroke-dasharray="4 6"/>
              <line x1="70" y1="90" x2="170" y2="90" stroke="#00e5ff" stroke-width="0.5" stroke-dasharray="3 8"/>
              <line x1="65" y1="110" x2="175" y2="110" stroke="#ff00ff" stroke-width="0.4" stroke-dasharray="2 10"/>
              <line x1="75" y1="130" x2="165" y2="130" stroke="#00e5ff" stroke-width="0.4" stroke-dasharray="4 6"/>
              <line x1="120" y1="50" x2="120" y2="170" stroke="#00e5ff" stroke-width="0.4" stroke-dasharray="2 8"/>
              <line x1="90" y1="55" x2="90" y2="150" stroke="#00e5ff" stroke-width="0.3" stroke-dasharray="2 10"/>
              <line x1="150" y1="55" x2="150" y2="150" stroke="#ff00ff" stroke-width="0.3" stroke-dasharray="2 10"/>
            </g>

            <!-- Arc Reactor outer ring -->
            <circle cx="120" cy="105" r="36" fill="none" stroke="#00e5ff" stroke-width="1" stroke-opacity="0.5"/>

            <!-- Arc Reactor tri-sections -->
            <path d="M120,69 L120,105 L149.2,122.5" fill="none" stroke="#00e5ff" stroke-width="0.8" stroke-opacity="0.6"/>
            <path d="M149.2,122.5 L120,105 L90.8,122.5" fill="none" stroke="#00e5ff" stroke-width="0.8" stroke-opacity="0.6"/>
            <path d="M90.8,122.5 L120,105 L120,69" fill="none" stroke="#00e5ff" stroke-width="0.8" stroke-opacity="0.6"/>

            <!-- Reactor ring segments with animation -->
            <circle cx="120" cy="105" r="28" fill="none" stroke="#00e5ff" stroke-width="2" stroke-opacity="0.4"
              stroke-dasharray="14 8" style="transform-origin:120px 105px;animation:rotateSlow 4s linear infinite"/>
            <circle cx="120" cy="105" r="20" fill="none" stroke="#ff00ff" stroke-width="1.5" stroke-opacity="0.5"
              stroke-dasharray="8 6" style="transform-origin:120px 105px;animation:rotateSlow 3s linear infinite reverse"/>

            <!-- Reactor glow background -->
            <circle cx="120" cy="105" r="24" fill="url(#reactorGlow)">
              <animate attributeName="r" values="20;26;20" dur="1.8s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.8;0.4;0.8" dur="1.8s" repeatCount="indefinite"/>
            </circle>

            <!-- Inner reactor core -->
            <circle cx="120" cy="105" r="10" fill="#001830" stroke="#00e5ff" stroke-width="1.5" stroke-opacity="0.8"/>
            <circle cx="120" cy="105" r="6" fill="url(#coreGlow)">
              <animate attributeName="r" values="5;7;5" dur="1.2s" repeatCount="indefinite"/>
            </circle>
            <circle cx="120" cy="105" r="3" fill="#ffffff" opacity="0.95"/>

            <!-- Energy nodes on outer ring -->
            <circle cx="120" cy="69" r="3" fill="#00e5ff" filter="url(#glow)">
              <animate attributeName="opacity" values="1;0.3;1" dur="1.8s" begin="0s" repeatCount="indefinite"/>
            </circle>
            <circle cx="149.2" cy="122.5" r="3" fill="#00e5ff" filter="url(#glow)">
              <animate attributeName="opacity" values="0.3;1;0.3" dur="1.8s" begin="0.6s" repeatCount="indefinite"/>
            </circle>
            <circle cx="90.8" cy="122.5" r="3" fill="#ff00ff" filter="url(#glow)">
              <animate attributeName="opacity" values="0.3;1;0.3" dur="1.8s" begin="1.2s" repeatCount="indefinite"/>
            </circle>

            <!-- ECG Heart Monitor Line -->
            <g id="ecg-group" clip-path="url(#heartClip)" opacity="0">
              <!-- Baseline -->
              <line x1="52" y1="162" x2="188" y2="162" stroke="#00ff88" stroke-width="0.5" stroke-opacity="0.25"/>
              <!-- Moving scan window effect -->
              <rect id="ecg-scan-mask" x="52" y="140" width="0" height="30" fill="#00ff88" opacity="0.04">
                <animate attributeName="width" values="0;136;136;0" dur="2.4s" repeatCount="indefinite"/>
                <animate attributeName="x" values="52;52;188;188" dur="2.4s" repeatCount="indefinite"/>
              </rect>
              <!-- ECG waveform path - PQRST complex repeating -->
              <path id="ecg-path"
                d="M52,162 L62,162 L65,162 L67,159 L68,162 L69,162
                   L73,162 L74,147 L75,177 L76,148 L77,162 L78,162
                   L82,162 L85,157 L87,158 L89,162 L90,162
                   L94,162 L97,159 L99,162 L100,162
                   L104,162 L107,162 L109,162 L110,162
                   L114,162 L115,147 L116,177 L117,148 L118,162
                   L122,162 L125,157 L127,158 L129,162
                   L133,162 L136,159 L137,162 L138,162
                   L142,162 L143,147 L144,177 L145,148 L146,162
                   L150,162 L153,157 L155,158 L157,162
                   L160,162 L163,162 L165,162 L166,162
                   L170,162 L171,147 L172,177 L173,148 L174,162
                   L178,162 L181,157 L183,158 L185,162 L188,162"
                fill="none" stroke="#00ff88" stroke-width="1.6"
                stroke-linecap="round" stroke-linejoin="round">
                <animate attributeName="stroke-opacity" values="0;0;0.9;0.9;0" dur="2.4s" repeatCount="indefinite"/>
              </path>
              <!-- Glowing dot sweeping across -->
              <circle r="2.5" fill="#00ff88" filter="url(#glow)">
                <animateMotion dur="2.4s" repeatCount="indefinite"
                  path="M52,162 L62,162 L65,162 L67,159 L68,162 L69,162 L73,162 L74,147 L75,177 L76,148 L77,162 L78,162 L82,162 L85,157 L87,158 L89,162 L90,162 L94,162 L97,159 L99,162 L100,162 L104,162 L107,162 L109,162 L110,162 L114,162 L115,147 L116,177 L117,148 L118,162 L122,162 L125,157 L127,158 L129,162 L133,162 L136,159 L137,162 L138,162 L142,162 L143,147 L144,177 L145,148 L146,162 L150,162 L153,157 L155,158 L157,162 L160,162 L163,162 L165,162 L166,162 L170,162 L171,147 L172,177 L173,148 L174,162 L178,162 L181,157 L183,158 L185,162 L188,162"/>
                <animate attributeName="opacity" values="0;0;1;1;0" dur="2.4s" repeatCount="indefinite"/>
              </circle>
            </g>

            <!-- Corner brackets - Tony Stark HUD style -->
            <path d="M20,20 L20,36 M20,20 L36,20" fill="none" stroke="#00e5ff" stroke-width="1.2" stroke-opacity="0.5"/>
            <path d="M220,20 L220,36 M220,20 L204,20" fill="none" stroke="#00e5ff" stroke-width="1.2" stroke-opacity="0.5"/>
            <path d="M20,220 L20,204 M20,220 L36,220" fill="none" stroke="#ff00ff" stroke-width="1.2" stroke-opacity="0.5"/>
            <path d="M220,220 L220,204 M220,220 L204,220" fill="none" stroke="#ff00ff" stroke-width="1.2" stroke-opacity="0.5"/>

            <!-- Scan line -->
            <line x1="30" y1="120" x2="210" y2="120" stroke="#00e5ff" stroke-width="0.5" stroke-opacity="0.15">
              <animate attributeName="y1" values="30;210;30" dur="3s" repeatCount="indefinite"/>
              <animate attributeName="y2" values="30;210;30" dur="3s" repeatCount="indefinite"/>
              <animate attributeName="stroke-opacity" values="0.15;0.05;0.15" dur="3s" repeatCount="indefinite"/>
            </line>

            <!-- Status text -->
            <text x="120" y="198" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="7" fill="#00e5ff" opacity="0.5" letter-spacing="3">MATRIX OS</text>
          </svg>
        </div>
        <!-- ECG MONITOR LINE - below heart, outside SVG -->
        <div id="ecg-wrap" style="width:220px;height:32px;margin-top:-8px;position:relative;opacity:0;transition:opacity 0.8s">
          <svg viewBox="0 0 220 32" width="220" height="32" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <filter id="ecgGlow"><feGaussianBlur stdDeviation="2" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            </defs>
            <!-- baseline -->
            <line x1="0" y1="16" x2="220" y2="16" stroke="#00ff88" stroke-width="0.4" stroke-opacity="0.2"/>
            <!-- ECG path -->
            <path d="M0,16 L18,16 L21,16 L23,11 L24,16 L25,16
                     L30,16 L31,3 L32,29 L33,4 L34,16 L35,16
                     L40,16 L43,10 L45,11 L47,16 L48,16
                     L55,16 L56,3 L57,29 L58,4 L59,16
                     L64,16 L67,10 L69,11 L71,16
                     L76,16 L79,16 L81,16
                     L86,16 L87,3 L88,29 L89,4 L90,16
                     L95,16 L98,10 L100,11 L102,16
                     L107,16 L110,16 L112,16
                     L117,16 L118,3 L119,29 L120,4 L121,16
                     L126,16 L129,10 L131,11 L133,16
                     L138,16 L141,16 L143,16
                     L148,16 L149,3 L150,29 L151,4 L152,16
                     L157,16 L160,10 L162,11 L164,16
                     L169,16 L172,16 L220,16"
              fill="none" stroke="#00ff88" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round"
              filter="url(#ecgGlow)" id="ecg-main-path">
              <animate attributeName="stroke-dasharray" values="0,800;800,0" dur="2.4s" repeatCount="indefinite"/>
              <animate attributeName="stroke-dashoffset" values="800;0" dur="2.4s" repeatCount="indefinite"/>
            </path>
            <!-- scanning dot -->
            <circle r="3" fill="#00ff88" filter="url(#ecgGlow)" id="ecg-dot">
              <animateMotion repeatCount="indefinite" dur="2.4s"
                path="M0,16 L18,16 L21,16 L23,11 L24,16 L25,16 L30,16 L31,3 L32,29 L33,4 L34,16 L35,16 L40,16 L43,10 L45,11 L47,16 L48,16 L55,16 L56,3 L57,29 L58,4 L59,16 L64,16 L67,10 L69,11 L71,16 L76,16 L79,16 L81,16 L86,16 L87,3 L88,29 L89,4 L90,16 L95,16 L98,10 L100,11 L102,16 L107,16 L110,16 L112,16 L117,16 L118,3 L119,29 L120,4 L121,16 L126,16 L129,10 L131,11 L133,16 L138,16 L141,16 L143,16 L148,16 L149,3 L150,29 L151,4 L152,16 L157,16 L160,10 L162,11 L164,16 L169,16 L172,16 L220,16"/>
            </circle>
          </svg>
        </div>
        <div id="logo-status">
          <div id="logo-sub">ELITE NEXUS AI</div>
          <div id="logo-main" class="gc">MATRIX // STANDBY</div>
        </div>
      </div>
    </div>

    <div style="min-height:260px;display:flex;flex-direction:column">
      <div class="tile tile-m sweep" style="flex:1" id="gpu1-tile">
        <div class="th"><span class="th-m" id="gpu1-title">GPU 1 • RTX 3090</span><span class="th-s" id="gpu1-fan">0% FAN</span></div>
        <div class="gpu-body">
          <div class="gauge-wrap" id="gpu1-temp"></div>
          <div class="gauge-wrap" id="gpu1-util"></div>
          <div class="gpu-bars">
            <div class="bar-wrap" id="gpu1-vram"></div>
            <div class="bar-wrap" id="gpu1-pwr"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Row 2 -->
    <div class="r2">
      <div class="tile sweep">
        <div class="th"><span class="th-c">CPU • I9 / 128GB</span><span class="th-s" id="cpu-up">0d 0h 0m</span></div>
        <div class="cpu-body">
          <div class="cpu-big">
            <div style="font-family:'JetBrains Mono',monospace;font-size:9px;text-transform:uppercase;letter-spacing:.25em;color:var(--muted-fg)">LOAD</div>
            <div class="cpu-pct gc" id="cpu-pct">0<span style="font-size:14px">%</span></div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted-fg)" id="cpu-freq">0.00 GHz</div>
            <div class="ga mono" style="font-size:10px;display:none" id="cpu-volt"></div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted-fg)" id="cpu-temp"></div>
          </div>
          <div class="cpu-right">
            <div style="font-family:'JetBrains Mono',monospace;font-size:9px;text-transform:uppercase;letter-spacing:.25em;color:var(--muted-fg)">CORE MATRIX</div>
            <div class="core-bars" id="core-bars"></div>
            <div class="bar-wrap" id="ram-bar"></div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px" id="disk-grid"></div>
          </div>
        </div>
      </div>
      <div class="tile tile-m sweep">
        <div class="th"><span class="th-m">LLM TELEMETRY</span><span class="th-s" id="llm-win">ROLLING 24H</span></div>
        <div class="llm-body">
          <div class="llm-stat br">
            <div class="llm-lbl">FREE TOKENS</div>
            <div class="llm-val gc" id="llm-free">0</div>
            <div class="llm-sub">local • ollama</div>
          </div>
          <div class="llm-stat">
            <div class="llm-lbl">PAID SPEND</div>
            <div class="llm-val gm" id="llm-paid">$0.00</div>
            <div class="llm-sub" id="llm-today">today $0.00</div>
