        <button class="btn-primary" style="width:100%;border-color:#00e5ff40"
          onclick="councilToProject()">→ SEND TO PROJECT SCAFFOLDING</button>
      </div>
    </div>
  </div>
</div>

<script>
/* ── PROJECT MODAL LOGIC ── */
function openProjectModal(){ document.getElementById('project-modal').classList.add('open') }
function closeModal(id){ document.getElementById(id).classList.remove('open') }

function toggleTool(el){
  el.classList.toggle('selected');
}

function getSelectedTools(){
  return Array.from(document.querySelectorAll('#tool-chips .tool-chip.selected'))
    .map(el => el.textContent);
}

async function createProject(){
  const name = document.getElementById('proj-name').value.trim();
  if(!name){ alert('Project name required'); return; }
  const payload = {
    name: name,
    service: document.getElementById('proj-service').value,
    brief: document.getElementById('proj-brief').value,
    indepth: document.getElementById('proj-indepth').value,
    tools: getSelectedTools(),
    build_prefs: document.getElementById('proj-prefs').value
  };
  const btn = event.target;
  btn.textContent = '⧗ CREATING...';
  btn.disabled = true;
  try {
    const r = await fetch('/projects/create', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify(payload)
    });
    const d = await r.json();
    const res = document.getElementById('proj-result');
    res.style.display = 'block';
    if(d.ok){
      res.textContent = '✅ Project scope created: ' + d.path;
      res.style.borderColor = '#00ff8825';
      res.style.color = '#00ff88';
      res.style.background = '#00ff8810';
      setTimeout(()=>closeModal('project-modal'), 2500);
      if(typeof addMsg === 'function')
        addMsg('system', '📋 Project "' + payload.name + '" scaffolded → ' + d.path);
    } else {
      res.textContent = '✗ Error: ' + d.error;
      res.style.color = '#ff3333';
    }
  } catch(e){
    document.getElementById('proj-result').textContent = '✗ ' + e.message;
    document.getElementById('proj-result').style.display = 'block';
  }
  btn.textContent = '→ CREATE PROJECT SCOPE';
  btn.disabled = false;
}

/* ── COUNCIL BOX LOGIC ── */
function openCouncilModal(){ document.getElementById('council-modal').classList.add('open') }

function handleCouncilDrop(e){
  e.preventDefault();
  document.getElementById('council-dz').classList.remove('drag-over');
  const text = e.dataTransfer.getData('text');
  if(text) document.getElementById('council-input').value = text;
  const files = e.dataTransfer.files;
  if(files.length > 0){
    const reader = new FileReader();
    reader.onload = ev => document.getElementById('council-input').value = ev.target.result;
    reader.readAsText(files[0]);
  }
}

async function triggerCouncil(){
  const content = document.getElementById('council-input').value.trim();
  if(!content){ alert('Please enter a concept or brief to analyze'); return; }
  document.getElementById('council-thinking').classList.add('visible');
  document.getElementById('council-result').classList.remove('visible');
  document.getElementById('council-to-project').style.display = 'none';
  try {
    const ctrl = new AbortController(); setTimeout(()=>ctrl.abort(), 120000);
    const r = await fetch('/council/analyze', {signal: ctrl.signal,
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({content, content_type:'text'})
    });
    const d = await r.json();
    document.getElementById('council-thinking').classList.remove('visible');
    if(d.ok){
      document.getElementById('council-result').textContent = d.analysis;
      document.getElementById('council-result').classList.add('visible');
      document.getElementById('council-to-project').style.display = 'block';
    } else {
      document.getElementById('council-result').textContent = 'Error: ' + d.error;
      document.getElementById('council-result').classList.add('visible');
    }
  } catch(e){
    document.getElementById('council-thinking').classList.remove('visible');
    document.getElementById('council-result').textContent = 'Error: ' + e.message;
    document.getElementById('council-result').classList.add('visible');
  }
}

function councilToProject(){
  const analysis = document.getElementById('council-result').textContent;
  document.getElementById('proj-indepth').value = analysis.substring(0, 1000);
  closeModal('council-modal');
  openProjectModal();
}
</script>

<script>
/* ── VAULT SYNC ── */
async function loadVaultFiles() {
  try {
    const r = await fetch('/vault/files');
    const d = await r.json();
    const kPanel = document.getElementById('vault-knowledge-list');
    const pPanel = document.getElementById('vault-production-list');
    const kCount = document.getElementById('vault-k-count');
    const pCount = document.getElementById('vault-p-count');

    if (kCount) kCount.textContent = d.knowledge.count + ' notes';
    if (pCount) pCount.textContent = d.production.count + ' notes';

    if (kPanel) {
      kPanel.innerHTML = '';
      (d.knowledge.files || []).slice(0, 8).forEach(f => {
        const div = document.createElement('div');
        div.style.cssText = 'padding:2px 0;border-bottom:1px solid #00e5ff08;font-size:8px;color:#00e5ffaa;cursor:pointer;overflow:hidden;text-overflow:ellipsis;white-space:nowrap';
        div.textContent = '📄 ' + f.name;
        div.title = f.path;
        div.onclick = () => readVaultNote(f.path, 'knowledge');
        kPanel.appendChild(div);
      });
    }
    if (pPanel) {
      pPanel.innerHTML = '';
      (d.production.files || []).slice(0, 8).forEach(f => {
        const div = document.createElement('div');
        div.style.cssText = 'padding:2px 0;border-bottom:1px solid #ff00ff08;font-size:8px;color:#ff00ffaa;cursor:pointer;overflow:hidden;text-overflow:ellipsis;white-space:nowrap';
        div.textContent = '📄 ' + f.name;
        div.title = f.path;
        div.onclick = () => readVaultNote(f.path, 'production');
        pPanel.appendChild(div);
      });
    }
  } catch(e) { console.warn('Vault load error:', e); }
}

async function readVaultNote(path, vault) {
  try {
    const r = await fetch('/vault/read', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({path, vault})
    });
    const d = await r.json();
    if (d.ok) {
      const el = document.getElementById('vault-note-viewer');
      if (el) {
        el.style.display = 'block';
        el.textContent = d.content;
        document.getElementById('vault-note-title').textContent = path;
      } else {
        alert('📄 ' + path + '\n\n' + d.content.substring(0, 500));
      }
    }
  } catch(e) {}
}

async function searchVault(query) {
  if (!query) return;
  const r = await fetch('/vault/search', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({query, vault:'both'})
  });
  const d = await r.json();
  if (typeof addMsg === 'function') {
    if (d.count === 0) {
      addMsg('system', '🔍 No vault results for: ' + query);
    } else {
      const hits = d.results.slice(0,3).map(r => '📄 ' + r.name + ': ' + r.snippet.substring(0,80)).join('\n');
      addMsg('system', '🔍 Vault search: ' + d.count + ' results\n' + hits);
    }
  }
}

async function generateDailySummary() {
  if (typeof addMsg === 'function') addMsg('system', '⧗ Generating daily summary...');
  try {
    const r = await fetch('/vault/daily-summary', {method:'POST'});
    const d = await r.json();
    if (d.ok && typeof addMsg === 'function') {
      addMsg('system', '✅ Daily summary saved → ' + d.path);
      loadVaultFiles();
    }
  } catch(e) {}
}

// Load on startup and refresh every 60s
document.addEventListener('DOMContentLoaded', () => {
  loadVaultFiles();
  setInterval(loadVaultFiles, 60000);
});

// Add /vault slash command
const _origHandleSlash = window.handleSlash;
window.handleVaultCmd = function(arg) {
  if (!arg) { loadVaultFiles(); return; }
  if (arg.startsWith('search ')) searchVault(arg.replace('search ',''));
  else if (arg === 'summary') generateDailySummary();
  else if (arg === 'sync') loadVaultFiles();
};
</script>

<style>
#agent-roster-panel{position:fixed;right:0;top:50%;transform:translateY(-50%);width:215px;background:#09101d;border:1px solid #00e5ff18;border-radius:6px 0 0 6px;padding:8px;z-index:5000;box-shadow:-4px 0 20px #000;transition:transform .3s;max-height:70vh;overflow-y:auto}
#agent-roster-panel.hidden{transform:translateY(-50%) translateX(100%)}
#agent-roster-toggle{position:fixed;right:0;top:calc(50% + 130px);width:22px;height:44px;background:#09101d;border:1px solid #00e5ff18;border-radius:4px 0 0 4px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:9px;color:#00e5ff44;z-index:5001}
.ari{display:flex;align-items:center;gap:5px;padding:3px 5px;border-radius:2px;cursor:pointer;border:1px solid transparent;margin-bottom:2px;transition:all .15s}
.ari:hover{background:#ffffff08}
.ari.active-agent{border-color:#00e5ff40;background:#00e5ff08}
</style>
<div id="agent-roster-toggle" onclick="document.getElementById('agent-roster-panel').classList.toggle('hidden')">⬡</div>
<div id="agent-roster-panel">
  <div style="font-size:7px;letter-spacing:1.5px;color:#00e5ff55;font-weight:bold;margin-bottom:5px;padding-bottom:3px;border-bottom:1px solid #00e5ff10">⬡ DEPT HEADS · CLICK TO CONNECT</div>
  <div id="agent-roster-list" style="font-size:8px"></div>
</div>
<script>
var _activeAgent='hermes-ceo'; window._activeAgent='hermes-ceo';
async function loadAgents(){
  try{
    var r=await fetch('/agents/registry');
    var d=await r.json();
    window._agents={};
    (d.agents||[]).forEach(function(a){window._agents[a.id]=a;});
    renderRoster(d.agents||[]);
  }catch(e){}
}
function renderRoster(agents){
  var el=document.getElementById('agent-roster-list');
  if(!el)return;
  el.innerHTML='';
  agents.forEach(function(a){
    var div=document.createElement('div');
    div.className='ari'+(a.id===_activeAgent?' active-agent':'');
    div.style.borderColor=a.id===_activeAgent?a.color+'50':'transparent';
    div.innerHTML='<span style="font-size:11px">'+a.icon+'</span><div style="flex:1;min-width:0"><div style="font-weight:bold;color:'+a.color+';overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:7.5px">'+a.name+'</div><div style="font-size:5.5px;color:#ffffff28">'+a.role+'</div></div><div style="width:4px;height:4px;border-radius:50%;background:'+(a.provider==='vllm'?'#00ff88':'#ffd700')+';flex-shrink:0"></div>';
    div.onclick=function(){switchAgent(a.id,a);};
    el.appendChild(div);
  });
}
function switchAgent(id,data){
  _activeAgent=id; window._activeAgent=id;
  window._activeAgentData=data;
  if(typeof addMsg==='function') addMsg('system','// Connected to '+data.name+' · '+data.role+' · '+data.model);
  if(window._agents) renderRoster(Object.values(window._agents));
  // Update chat header if elements exist
  var ne=document.getElementById('active-agent-name');
  var re=document.getElementById('active-agent-role');
  if(ne) ne.textContent=data.name;
  if(re) re.textContent=data.role+' · '+data.model;
}
document.addEventListener('DOMContentLoaded',function(){ loadAgents(); });
</script>

<script>
var _ceoAutoRoute = true;
function toggleAutoRoute(){
  var btn = document.getElementById('ceo-route-toggle');
  if(btn){ btn.textContent = _ceoAutoRoute ? 'O CEO AUTO' : 'O MANUAL'; btn.style.color = _ceoAutoRoute ? '#00e5ff' : '#ffffff33'; }
}
// Intercept send via event listener on the textarea
document.addEventListener('DOMContentLoaded', function(){
  setTimeout(function(){
    var ta = document.getElementById('cmd-in');
    if(tail -5 /tmp/matrix-bridge.log) return;
    ta.addEventListener('keydown', function(e){
      if(e.key !== 'Enter' || e.shiftKey) return;
      var msg = ta.value.trim();
      var agent = window._agents && window._agents[_activeAgent];
      e.preventDefault(); e.stopImmediatePropagation();
      ta.value = '';
      if(typeof addMsg === 'function') addMsg('user', msg);
      if(typeof addMsg === 'function') addMsg('system', 'o ' + agent.name + ' thinking...');
      fetch('/ceo/orchestrate', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({message:msg, agent_id:_activeAgent})})
        .then(function(r){ return r.json(); })
        .then(function(d){
          if(d.ok && typeof addMsg === 'function') addMsg('assistant', d.response);
          else if(typeof addMsg === 'function') addMsg('system', 'x ' + (d.error||'error'));
          if(window.fetchTelSession) fetchTelSession();
        })
        .catch(function(ex){ if(typeof addMsg === 'function') addMsg('system', 'x ' + ex.message); });
    }, true);
    console.log('CEO routing hook attached');
  }, 3000);
});
</script>

<script>
function ceoSend(msg){
  var ta = document.getElementById('cmd-in');
  var agent = window._agents && window._agents[_activeAgent];
  if(ta) ta.value = '';
  if(typeof addMsg === 'function') addMsg('user', msg);
  if(typeof addMsg === 'function') addMsg('system', 'o ' + agent.name + ' thinking...');
  fetch('/ceo/orchestrate',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({message:msg,agent_id:_activeAgent})})
  .then(function(r){return r.json();})
  .then(function(d){
    if(d.ok && typeof addMsg==='function') addMsg('assistant', d.response);
    else if(typeof addMsg==='function') addMsg('system','x '+(d.error||'error'));
    if(window.fetchTelSession) fetchTelSession();
  }).catch(function(ex){if(typeof addMsg==='function') addMsg('system','x '+ex.message);});
}
</script>

<script>
