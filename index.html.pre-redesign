          <span style="font-size:6px;padding:1px 5px;border:1px solid #aa44ff18;color:#aa44ff44;border-radius:2px">.pdf</span>
          <span style="font-size:6px;padding:1px 5px;border:1px solid #aa44ff18;color:#aa44ff44;border-radius:2px">.txt</span>
          <span style="font-size:6px;padding:1px 5px;border:1px solid #aa44ff18;color:#aa44ff44;border-radius:2px">.md</span>
          <span style="font-size:6px;padding:1px 5px;border:1px solid #aa44ff18;color:#aa44ff44;border-radius:2px">.docx</span>
          <span style="font-size:6px;padding:1px 5px;border:1px solid #aa44ff18;color:#aa44ff44;border-radius:2px">URL</span>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" style="color:#aa44ff66">OR TYPE / PASTE YOUR CONCEPT</label>
        <textarea class="form-textarea" id="council-input" style="border-color:#aa44ff18;color:#aa44ffaa;min-height:80px"
          placeholder="Describe the business model, project idea, client brief, or operational concept you want analyzed..."></textarea>
      </div>
      <div style="display:flex;gap:6px">
        <button class="btn-primary" style="flex:1;border-color:#aa44ff40;color:#aa44ff"
          onclick="triggerCouncil()">🏛 TRIGGER COUNCIL ANALYSIS</button>
