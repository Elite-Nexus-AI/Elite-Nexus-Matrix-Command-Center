<div class="modal-overlay" id="project-modal">
  <div class="modal-box">
    <div class="modal-hdr">
      <span class="modal-title">📋 NEW PROJECT · TASK SCAFFOLDING</span>
      <button class="modal-close" onclick="closeModal('project-modal')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">SERVICE TYPE</label>
        <select class="form-select" id="proj-service">
          <option>AI Smart Websites</option>
          <option>AI Chatbots & Text Bots</option>
          <option>AI Voice Bots</option>
          <option>IVR Phone Systems</option>
          <option>AI Agents</option>
          <option>AI Super Agents</option>
          <option>AI Workflows</option>
          <option>AI Consulting</option>
          <option>AI Social Media Marketing</option>
          <option>AI Marketing Campaigns</option>
          <option>AI CRM</option>
          <option>Cybersecurity</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">PROJECT NAME</label>
        <input class="form-input" id="proj-name" placeholder="e.g. LawFirm Landing Page v2">
      </div>
      <div class="form-group">
        <label class="form-label">BRIEF DESCRIPTION</label>
        <input class="form-input" id="proj-brief" placeholder="One-line summary of what this project does">
      </div>
      <div class="form-group">
        <label class="form-label">IN-DEPTH DESCRIPTION</label>
        <textarea class="form-textarea" id="proj-indepth" placeholder="Full feature list, requirements, target audience, technical specs..."></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">TOOL ASSIGNMENT (click to select)</label>
        <div class="tool-chips" id="tool-chips">
          <span class="tool-chip" onclick="toggleTool(this)">n8n</span>
          <span class="tool-chip" onclick="toggleTool(this)">Dify</span>
          <span class="tool-chip" onclick="toggleTool(this)">Next.js</span>
          <span class="tool-chip" onclick="toggleTool(this)">FastAPI</span>
          <span class="tool-chip" onclick="toggleTool(this)">LangGraph</span>
          <span class="tool-chip" onclick="toggleTool(this)">Claude Code</span>
          <span class="tool-chip" onclick="toggleTool(this)">Vercel</span>
          <span class="tool-chip" onclick="toggleTool(this)">VAPI</span>
          <span class="tool-chip" onclick="toggleTool(this)">Twilio</span>
          <span class="tool-chip selected" onclick="toggleTool(this)">Auto</span>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">BUILD PREFERENCES</label>
        <input class="form-input" id="proj-prefs" placeholder="e.g. Prioritize speed, mobile-first, dark mode only">
      </div>
      <div id="proj-result" style="display:none;padding:8px;background:#00ff8810;border:1px solid #00ff8825;border-radius:3px;font-size:8px;color:#00ff88;margin-top:8px"></div>
    </div>
    <div class="modal-footer">
      <button class="btn-secondary" onclick="closeModal('project-modal')">CANCEL</button>
      <button class="btn-primary" onclick="createProject()">→ CREATE PROJECT SCOPE</button>
    </div>
  </div>
</div>

