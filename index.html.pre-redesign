  <div style="font-size:10px;letter-spacing:2px;color:#aa44ffcc;font-weight:bold;margin-bottom:8px;border-bottom:1px solid #aa44ff25;padding-bottom:6px;text-shadow:0 0 8px #aa44ff44">🗄 VAULT ASSIGNMENT</div>
  <div style="font-size:9px;color:#aa44ff99;margin-bottom:8px;letter-spacing:1px;font-weight:bold" id="va-agent-label">HERMES · CEO</div>
  <div class="va-row"><span class="va-lbl">Daily Notes</span><select class="va-sel" id="va-daily"><option>New-matrix-vault/daily</option><option>Matrix-Production/logs</option></select></div>
  <div class="va-row"><span class="va-lbl">Projects</span><select class="va-sel" id="va-projects"><option>Matrix-Production/projects</option><option>New-matrix-vault/projects</option></select></div>
  <div class="va-row"><span class="va-lbl">Knowledge</span><select class="va-sel" id="va-knowledge"><option>New-matrix-vault/knowledge</option><option>Matrix-Production/kb</option><option>Matrix-Production/projects/cfo/research</option></select></div>
  <div style="border-top:1px solid #aa44ff25;margin:10px 0;padding-top:8px">
    <div class="va-row"><span class="va-lbl" style="width:130px;font-size:9px">Auto-chunk (450 lines)</span><div class="va-tog on" id="va-chunk" onclick="this.classList.toggle('on')"></div></div>
    <div class="va-row"><span class="va-lbl" style="width:130px;font-size:9px">Chapter split</span><div class="va-tog on" id="va-chapter" onclick="this.classList.toggle('on')"></div></div>
    <div class="va-row"><span class="va-lbl" style="width:130px;font-size:9px">Daily auto-summary</span><div class="va-tog on" id="va-summary" onclick="this.classList.toggle('on')"></div></div>
  </div>
  <button onclick="saveVaultAssign()" style="width:100%;padding:6px;background:#aa44ff15;border:1px solid #aa44ff45;color:#cc88ff;font-family:inherit;font-size:9px;cursor:pointer;border-radius:3px;letter-spacing:1px;font-weight:bold">💾 SAVE CONFIG</button>
  <div id="va-status" style="font-size:9px;color:#00ff8899;margin-top:5px;text-align:center;font-weight:bold"></div>
</div>
<script>
async function loadVaultAssign(agentId){
  try{
    var r = await fetch('/vault/assign');
    var d = await r.json();
    var config = d.assignments && d.assignments[agentId];
    if(!config) return;
    var dl = document.getElementById('va-daily');
    var pr = document.getElementById('va-projects');
    var kn = document.getElementById('va-knowledge');
    if(dl) dl.value = config.daily_notes || dl.options[0].value;
    if(pr) pr.value = config.projects || pr.options[0].value;
    if(kn) kn.value = config.knowledge || kn.options[0].value;
    var chunk = document.getElementById('va-chunk');
    var chapter = document.getElementById('va-chapter');
    var summary = document.getElementById('va-summary');
    if(chunk) chunk.classList.toggle('on', !!config.auto_chunk);
    if(chapter) chapter.classList.toggle('on', !!config.chapter_split);
    if(summary) summary.classList.toggle('on', !!config.auto_summary);
    var lbl = document.getElementById('va-agent-label');
    if(lbl && window._agents && window._agents[agentId]) lbl.textContent = window._agents[agentId].name;
  }catch(e){}
}

async function saveVaultAssign(){
  var agentId = typeof _activeAgent !== 'undefined' ? _activeAgent : 'hermes-ceo';
  var payload = {
    agent_id: agentId,
    daily_notes: document.getElementById('va-daily').value,
    projects: document.getElementById('va-projects').value,
    knowledge: document.getElementById('va-knowledge').value,
    auto_chunk: document.getElementById('va-chunk').classList.contains('on'),
    chunk_size: 450,
    chapter_split: document.getElementById('va-chapter').classList.contains('on'),
    auto_summary: document.getElementById('va-summary').classList.contains('on')
  };
  try{
    var r = await fetch('/vault/assign',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    var d = await r.json();
    var st = document.getElementById('va-status');
    if(d.ok){ st.textContent = 'Saved!'; st.style.color = '#00ff88'; }
    else { st.textContent = 'Error: '+d.error; st.style.color = '#ff3333'; }
    setTimeout(function(){ if(st) st.textContent=''; },2000);
  }catch(ex){ console.warn(ex); }
}

// Update vault panel when agent switches
var _origSwitchAgent = window.switchAgent;
window.switchAgent = function(id, data){
  if(_origSwitchAgent) _origSwitchAgent(id, data);
  loadVaultAssign(id);
};

document.addEventListener('DOMContentLoaded', function(){
  setTimeout(function(){ loadVaultAssign('hermes-ceo'); }, 2000);
});
</script>

<script>
/* ── NEURAL BRAIN VAULT VISUALIZATION ── */
var _brainData = null;
var _brainCanvas = null;
var _brainCtx = null;
var _brainAnimId = null;
var _brainView = 'brain'; // brain or graph
var _brainParticles = [];

var REGION_COLORS = {
    prefrontal:  '#00e5ff',
    motor:       '#ffd700',
    sensory:     '#ffffff',
    associative: '#00ff88',
    brainstem:   '#0088ff',
    reflex:      '#ff3355',
    concept:     '#ff00ff',
    cerebellum:  '#aa44ff'
};

var REGION_POSITIONS = {
    prefrontal:  {x: 0.5,  y: 0.18},
    motor:       {x: 0.25, y: 0.32},
    sensory:     {x: 0.75, y: 0.32},
    associative: {x: 0.5,  y: 0.45},
    brainstem:   {x: 0.5,  y: 0.78},
    reflex:      {x: 0.2,  y: 0.6},
    concept:     {x: 0.8,  y: 0.6},
    cerebellum:  {x: 0.35, y: 0.72}
};

async function loadBrainMap() {
    try {
        var r = await fetch('/brain/map');
        _brainData = await r.json();
        buildParticles();
        updateBrainStats();
    } catch(e) { console.warn('Brain map error:', e); }
}

function buildParticles() {
    if(!_brainData || !_brainData.regions) return;
    _brainParticles = [];
    var canvas = document.getElementById('brain-canvas');
    if(!canvas) return;
    var W = canvas.width, H = canvas.height;

    Object.keys(_brainData.regions).forEach(function(region) {
        var nodes = _brainData.regions[region];
        var pos = REGION_POSITIONS[region] || {x:0.5, y:0.5};
        var color = REGION_COLORS[region] || '#00e5ff';
        var cx = pos.x * W, cy = pos.y * H;
        var spread = Math.max(30, Math.min(60, nodes.length * 8));

        // Add region particles
        var count = Math.max(3, Math.min(20, nodes.length * 3 + 5));
        for(var i = 0; i < count; i++) {
            var angle = (Math.PI * 2 * i) / count + Math.random() * 0.5;
            var dist = Math.random() * spread;
            var firing = nodes.length > 0 ?
                nodes[Math.floor(Math.random() * nodes.length)].firing || 0.3 : 0.1;
            _brainParticles.push({
                x: cx + Math.cos(angle) * dist,
                y: cy + Math.sin(angle) * dist,
                vx: (Math.random() - 0.5) * 0.3,
                vy: (Math.random() - 0.5) * 0.3,
                cx: cx, cy: cy,
                color: color,
                region: region,
                firing: firing,
                size: 1 + firing * 2.5,
                alpha: 0.3 + firing * 0.7,
                pulse: Math.random() * Math.PI * 2
            });
        }
    });
}

function animateBrain() {
    var canvas = document.getElementById('brain-canvas');
    if(!canvas) return;
    var ctx = canvas.getContext('2d');
    var W = canvas.width, H = canvas.height;

    ctx.fillStyle = 'rgba(4,7,13,0.15)';
    ctx.fillRect(0,0,W,H);

    var t = Date.now() / 1000;

    // Draw connection lines between regions
    if(_brainData && _brainData.regions) {
        var connections = [
            ['prefrontal','motor'],['prefrontal','sensory'],
            ['prefrontal','associative'],['associative','brainstem'],
            ['motor','cerebellum'],['sensory','concept'],
            ['reflex','cerebellum']
        ];
        connections.forEach(function(pair) {
            var p1 = REGION_POSITIONS[pair[0]], p2 = REGION_POSITIONS[pair[1]];
            if(!p1||!p2) return;
            var n1 = (_brainData.regions[pair[0]]||[]).length;
            var n2 = (_brainData.regions[pair[1]]||[]).length;
            if(n1===0 && n2===0) return;
            ctx.beginPath();
            ctx.moveTo(p1.x*W, p1.y*H);
            ctx.lineTo(p2.x*W, p2.y*H);
            ctx.strokeStyle = 'rgba(0,229,255,0.08)';
            ctx.lineWidth = 0.5;
            ctx.stroke();
        });
    }

    // Animate particles
    _brainParticles.forEach(function(p) {
        p.pulse += 0.02;
        var pulseAlpha = p.alpha * (0.7 + 0.3 * Math.sin(p.pulse));

        // Gentle drift back to center
        p.vx += (p.cx - p.x) * 0.001;
        p.vy += (p.cy - p.y) * 0.001;
        p.vx *= 0.98;
        p.vy *= 0.98;
        p.x += p.vx;
        p.y += p.vy;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI*2);
        ctx.fillStyle = p.color + Math.floor(pulseAlpha * 255).toString(16).padStart(2,'0');
        ctx.fill();
    });

    // Draw region labels
    if(_brainData && _brainData.regions) {
        ctx.font = '8px Courier New';
        Object.keys(REGION_POSITIONS).forEach(function(region) {
            var nodes = _brainData.regions[region] || [];
            if(nodes.length === 0) return;
            var pos = REGION_POSITIONS[region];
            var color = REGION_COLORS[region];
            var avgFiring = nodes.reduce(function(s,n){return s+n.firing;},0)/nodes.length;
            ctx.fillStyle = color + 'aa';
            ctx.fillText(region.toUpperCase(), pos.x*W - 20, pos.y*H - 14);
            ctx.fillStyle = color + '66';
            ctx.fillText(nodes.length+'n · '+(avgFiring*100).toFixed(0)+'%', pos.x*W - 20, pos.y*H - 5);
        });
    }

    _brainAnimId = requestAnimationFrame(animateBrain);
}

function updateBrainStats() {
    if(!_brainData) return;
    var totalEl = document.getElementById('brain-total-nodes');
    var firingEl = document.getElementById('brain-firing');
    if(totalEl) totalEl.textContent = _brainData.total_nodes + ' nodes';
    if(firingEl) firingEl.textContent = ((_brainData.avg_firing||0)*100).toFixed(1) + '% firing';
}

function initBrainCanvas() {
    var canvas = document.getElementById('brain-canvas');
    if(canvas) {
        canvas.addEventListener('mousemove', function(e) {
            var rect = canvas.getBoundingClientRect();
            var mx = e.clientX - rect.left;
            var my = e.clientY - rect.top;
            var tip = document.getElementById('brain-tooltip');
            var closest = null, closestDist = 20;
            _brainParticles.forEach(function(p) {
                var dx = p.x - mx, dy = p.y - my;
                var dist = Math.sqrt(dx*dx + dy*dy);
                if(dist < closestDist) { closestDist = dist; closest = p; }
            });
            if(closest && tip) {
                var region = closest.region.toUpperCase();
                var color = REGION_COLORS[closest.region] || '#00e5ff';
                var nodes = (_brainData && _brainData.regions && _brainData.regions[closest.region]) || [];
                tip.style.display = 'block';
                tip.style.left = (e.clientX + 12) + 'px';
                tip.style.top = (e.clientY - 10) + 'px';
                tip.style.borderColor = color + '60';
                tip.style.color = color;
                tip.innerHTML = '<b>' + region + '</b><br>' + nodes.length + ' nodes · ' + (closest.firing*100).toFixed(0) + '% firing';
            } else if(tip) {
                tip.style.display = 'none';
            }
        });
        canvas.addEventListener('mouseleave', function() {
            var tip = document.getElementById('brain-tooltip');
            if(tip) tip.style.display = 'none';
        });
    }
    var canvas = document.getElementById('brain-canvas');
    if(!canvas) return;
    canvas.width = canvas.offsetWidth || 300;
    canvas.height = canvas.offsetHeight || 200;
    loadBrainMap();
    animateBrain();
    setInterval(loadBrainMap, 30000);
}

function toggleBrainView() {
    _brainView = _brainView === 'brain' ? 'graph' : 'brain';
    var btn = document.getElementById('brain-view-btn');
    if(btn) btn.textContent = _brainView === 'brain' ? '◈ GRAPH VIEW' : '⬡ BRAIN VIEW';
}

document.addEventListener('DOMContentLoaded', function(){
    setTimeout(initBrainCanvas, 2500);
});
</script>

<style>
#brain-panel{
  position:fixed;bottom:32px;right:220px;
